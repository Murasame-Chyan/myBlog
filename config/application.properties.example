# ============================================================
# myBlog 外部配置文件模板
# ============================================================
# 使用方法:
#   1. 复制此文件为 application.properties
#   2. 填入真实值
#   3. 将 application.properties 放在 myblog.jar 同级目录
#      （或放在 jar 同级的 config/ 目录下）
#   4. 启动: java -jar myblog.jar
# ============================================================

# --- 服务器端口 ---
server.port=8080

# --- 激活的 profile (dev/prod) ---
spring.profiles.active=dev

# --- 数据库 ---
spring.datasource.url=jdbc:mysql://localhost:3306/myblog
spring.datasource.username=root
spring.datasource.password=你的数据库密码

# --- 心知天气 API (https://www.seniverse.com/) ---
weather.seniverse.uid=你的心知天气公钥
weather.seniverse.key=你的心知天气私钥

# --- GitHub Personal Access Token (可选，仅用于提高仓库 API 速率限制) ---
# github.token=你的GitHub_Token

# --- 腾讯云 COS 对象存储 ---
tencent.cos.secret-id=你的腾讯云SecretId
tencent.cos.secret-key=你的腾讯云SecretKey
tencent.cos.region=ap-guangzhou
tencent.cos.bucket-name=你的存储桶名称
tencent.cos.base-url=https://你的存储桶名称.cos.ap-guangzhou.myqcloud.com
tencent.cos.folder=blog/images
